# Node-RED Connection
NODE_RED_URL=http://localhost:1880

# Authentication (use one method)
NODE_RED_TOKEN=your-bearer-token-here
# NODE_RED_ACCESS_TOKEN=alternative-name-for-same-token
# NODE_RED_USERNAME=admin
# NODE_RED_PASSWORD=your-password

# MCP Server (for SSE and streamable HTTP transports)
MCP_SERVER_PORT=3000
